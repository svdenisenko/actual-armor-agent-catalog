{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://github.com/svdenisenko/actual-armor-agent-catalog/catalog/schemas/agent.schema.json",
  "title": "Actual Armor Marketplace Agent Catalog Record",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "id",
    "name",
    "slug",
    "status",
    "category",
    "target_user",
    "public_safe_value",
    "short_description",
    "long_description",
    "opening_message",
    "required_inputs",
    "expected_output_format",
    "suggested_tools",
    "safety_rules",
    "source_discipline_rules",
    "public_private_notes",
    "aaf_link",
    "qa_status",
    "creation_status",
    "source_files",
    "duplicate_overlap_notes",
    "sendpulse_use_cases",
    "recommended_email_cta",
    "do_not_claim",
    "last_verified_date"
  ],
  "properties": {
    "id": { "type": "string", "minLength": 1 },
    "name": { "type": "string", "minLength": 1 },
    "slug": { "type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$" },
    "status": {
      "type": "string",
      "enum": [
        "LIVE_IN_AAF",
        "READY_FOR_LIMITED_TESTING",
        "AAF_CREATE_READY",
        "DRAFT",
        "NEEDS_PRODUCT_REVIEW",
        "NEEDS_QA",
        "HOLD",
        "REPOSITION_REQUIRED",
        "NEEDS_AAF_EXPORT"
      ]
    },
    "category": { "type": "string", "minLength": 1 },
    "target_user": { "type": "array", "items": { "type": "string" } },
    "public_safe_value": { "type": "string" },
    "short_description": { "type": "string" },
    "long_description": { "type": "string" },
    "opening_message": { "type": "string" },
    "required_inputs": { "type": "array", "items": { "type": "string" } },
    "expected_output_format": { "type": "array", "items": { "type": "string" } },
    "suggested_tools": { "type": "array", "items": { "type": "string" } },
    "safety_rules": { "type": "array", "items": { "type": "string" } },
    "source_discipline_rules": { "type": "array", "items": { "type": "string" } },
    "public_private_notes": { "type": "string" },
    "aaf_link": { "type": ["string", "null"] },
    "qa_status": { "type": "string" },
    "creation_status": { "type": "string" },
    "source_files": { "type": "array", "items": { "type": "string" } },
    "duplicate_overlap_notes": { "type": "string" },
    "sendpulse_use_cases": { "type": "array", "items": { "type": "string" } },
    "recommended_email_cta": { "type": "string" },
    "do_not_claim": { "type": "array", "items": { "type": "string" } },
    "last_verified_date": { "type": "string", "format": "date" }
  }
}
